# GitHub Personal Access Token — used ONLY by the offline data pipeline, never at runtime.
# A classic token with NO scopes works for public repo data (raises rate limit to 5,000 pts/hr),
# or a fine-grained token with "Public repositories (read-only)" access.
# Create one at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# Analysis window (defaults to the last 90 days if unset)
# WINDOW_START=2026-03-19
# WINDOW_END=2026-06-17
